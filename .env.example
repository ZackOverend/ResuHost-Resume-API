# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# DATABASE_TARGET controls which URL is used to connect to the database.
# Three modes are supported: auto (default), local, and supabase.
# Only set the variables relevant to your chosen mode.
# =============================================================================

# -----------------------------------------------------------------------------
# MODE: auto (default)
# -----------------------------------------------------------------------------
# Omit DATABASE_TARGET or set it to "auto".
# The app will connect using DATABASE_URL directly.
# Good for Docker and simple single-environment setups.
#
DATABASE_TARGET=auto
DATABASE_URL=postgresql://resume_user:resume_pass@db:5432/resume_db

# -----------------------------------------------------------------------------
# MODE: local
# -----------------------------------------------------------------------------
# Set DATABASE_TARGET=local to connect to a local Postgres instance.
# Useful when switching between local and remote without changing DATABASE_URL.
#
# DATABASE_TARGET=local
# LOCAL_DATABASE_URL=postgresql://resume_user:resume_pass@localhost:5432/resume_db

# -----------------------------------------------------------------------------
# MODE: supabase
# -----------------------------------------------------------------------------
# Set DATABASE_TARGET=supabase to connect to a Supabase Postgres instance.
#
# Get your connection string from:
#   Supabase Dashboard > Settings > Database > Connection pooling
#   Use the "Session mode" URI (port 6543). Direct connections (port 5432)
#   are often blocked by firewalls and ISPs.
#
# If your password contains special characters (e.g. @), URL-encode them:
#   @ -> %40    # -> %23    ! -> %21
#
# DATABASE_TARGET=supabase
# SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# =============================================================================
# OLLAMA CONFIGURATION
# =============================================================================
# Used by the POST /resume/{user_id}/tailor endpoint.
# These values are passed per-request in the request body and can be overridden
# there. The values below serve as a reference for the defaults.
#
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:cloud
#
# When running locally outside Docker, use localhost instead:
#
# OLLAMA_HOST=http://localhost:11434
