# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# DATABASE_TARGET controls which database the app connects to.
# Two modes are supported: local and supabase.
# COMPOSE_PROFILES must match — it controls whether Docker starts a local
# Postgres container alongside the API.
# =============================================================================

# -----------------------------------------------------------------------------
# MODE: local
# -----------------------------------------------------------------------------
# Docker starts a local Postgres container and the API connects to it.
# COMPOSE_PROFILES=local activates the db service in docker-compose.yml.
#
DATABASE_TARGET=local
LOCAL_DATABASE_URL=postgresql://resume_user:resume_pass@db:5432/resume_db
COMPOSE_PROFILES=local  # activates the db service in docker-compose.yml

# -----------------------------------------------------------------------------
# MODE: supabase
# -----------------------------------------------------------------------------
# Connects to a Supabase Postgres instance. Docker does NOT start a local
# Postgres container.
#
# Get your connection string from:
#   Supabase Dashboard > Settings > Database > Connection pooling
#   Use the "Session mode" URI (port 6543). Direct connections (port 5432)
#   are often blocked by firewalls and ISPs.
#
# If your password contains special characters (e.g. @), URL-encode them:
#   @ -> %40    # -> %23    ! -> %21
#
# DATABASE_TARGET=supabase
# SUPABASE_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# COMPOSE_PROFILES=supabase  # no local Postgres container

# =============================================================================
# OLLAMA CONFIGURATION
# =============================================================================
# Used by the POST /resume/{user_id}/tailor endpoint.
# These values are passed per-request in the request body and can be overridden
# there. The values below serve as a reference for the defaults.
#
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:cloud

# Ollama Cloud (uncomment and set your API key to use the hosted service):
# OLLAMA_HOST=https://api.ollama.com
# OLLAMA_API_KEY=your_ollama_api_key

# Running locally outside Docker (uncomment to override):
# OLLAMA_HOST=http://localhost:11434
