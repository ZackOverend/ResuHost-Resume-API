# Default: use DATABASE_URL only (omit DATABASE_TARGET or set DATABASE_TARGET=auto).
# Production / single-URL deploys: set DATABASE_URL.
DATABASE_URL=postgresql://user:password@localhost:5432/resume_api

# Optional: switch between two saved URLs without editing DATABASE_URL.
# DATABASE_TARGET=local
# LOCAL_DATABASE_URL=postgresql://user:password@localhost:5432/resume_api

# DATABASE_TARGET=supabase
# Supabase direct connection (port 5432) from Project Settings > Database.
# Add ?sslmode=require if your client string does not already include SSL params.
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
